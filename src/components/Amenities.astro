---
import { categories, groupedAmenities, icons } from "../data/amenities";
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="flex flex-col items-center gap-4 mb-12 px-15">
      <span class="font-body text-sm font-medium text-gold-warm tracking-[3px]">
        EXPERIENCE LUXURY
      </span>
      <h2
        class="font-headline text-3xl md:text-[42px] font-medium text-text-primary"
      >
        Hotel Amenities
      </h2>
      <div class="w-15 h-0.75 bg-sky-blue"></div>
      <p class="font-body text-base text-medium-gray text-center max-w-lg">
        Discover world-class facilities designed for your comfort and
        convenience
      </p>
    </div>

    <!-- Carousel Wrapper -->
    <div class="flex items-center justify-center gap-6 lg:px-10">
      <!-- Left Arrow -->
      <button
        type="button"
        class="hidden md:flex items-center justify-center w-13 h-13 rounded-full bg-white border border-border-gray shadow-[0_2px_8px_rgba(0,0,0,0.06)] hover:bg-light-gray transition-colors shrink-0"
        id="amenities-prev"
        aria-label="Previous amenities"
      >
        <svg
          class="w-6 h-6 text-text-primary"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <!-- Swiper Container -->
      <div class="swiper amenities-swiper w-full">
        <div class="swiper-wrapper py-8">
          {
            groupedAmenities.map((amenity) => (
              <div
                class="swiper-slide h-auto"
                data-category={amenity.category.toLowerCase()}
              >
                <div class="bg-white rounded-xl overflow-hidden shadow-[0_4px_16px_rgba(0,0,0,0.08)] h-full">
                  <img
                    src={amenity.image}
                    alt={amenity.title}
                    class="w-full h-50 object-cover"
                  />
                  <div class="p-6 flex flex-col gap-3">
                    <div
                      class:list={[
                        "w-11 h-11 rounded-full flex items-center justify-center",
                        amenity.iconColor === "sky-blue"
                          ? "bg-sky-blue/10"
                          : "bg-gold-warm/10",
                      ]}
                    >
                      <svg
                        class:list={[
                          "w-5.5 h-5.5",
                          amenity.iconColor === "sky-blue"
                            ? "text-sky-blue"
                            : "text-gold-warm",
                        ]}
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        viewBox="0 0 24 24"
                        set:html={icons[amenity.icon]}
                      />
                    </div>
                    <h3 class="font-headline text-[22px] font-medium text-text-primary">
                      {amenity.title}
                    </h3>
                    <p class="font-body text-[13px] text-medium-gray leading-relaxed">
                      {amenity.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right Arrow -->
      <button
        type="button"
        class="hidden md:flex items-center justify-center w-13 h-13 rounded-full bg-sky-blue shadow-[0_2px_8px_rgba(108,180,217,0.3)] hover:bg-sky-blue-light transition-colors shrink-0"
        id="amenities-next"
        aria-label="Next amenities"
      >
        <svg
          class="w-6 h-6 text-white"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Indicator Area -->
    <div class="flex flex-col items-center gap-8 mt-12 px-15">
      <!-- Pagination Dots -->
      <div class="amenities-pagination"></div>

      <!-- Category Pills -->
      <div
        class="flex flex-wrap justify-center gap-4"
        id="amenities-categories"
      >
        {
          categories.map((category, index) => (
            <button
              type="button"
              class:list={[
                "font-body text-[13px] font-medium px-6 py-3 rounded-full transition-colors",
                index === 0
                  ? "bg-sky-blue text-white"
                  : "bg-light-gray text-text-primary hover:bg-border-gray",
              ]}
              data-category={category.toLowerCase()}
            >
              {category}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination } from 'swiper/modules';
  import 'swiper/css';

  const swiper = new Swiper('.amenities-swiper', {
    modules: [Navigation, Pagination],
    slidesPerView: 1,
    slidesPerGroup: 1,
    spaceBetween: 16,
    breakpoints: {
      768: {
        slidesPerView: 2,
        slidesPerGroup: 2,
        spaceBetween: 32,
      },
    },
    navigation: {
      nextEl: '#amenities-next',
      prevEl: '#amenities-prev',
    },
    pagination: {
      el: '.amenities-pagination',
      clickable: true,
    },
  });

  function updateCategoryPills(activeCategory: string) {
    document.querySelectorAll('#amenities-categories button').forEach((btn) => {
      const btnEl = btn as HTMLElement;
      const isActive = btnEl.dataset.category === activeCategory;
      btnEl.classList.toggle('bg-sky-blue', isActive);
      btnEl.classList.toggle('text-white', isActive);
      btnEl.classList.toggle('bg-light-gray', !isActive);
      btnEl.classList.toggle('text-text-primary', !isActive);
      btnEl.classList.toggle('hover:bg-border-gray', !isActive);
    });
  }

  swiper.on('slideChange', () => {
    const activeCategory = (swiper.slides[swiper.activeIndex] as HTMLElement)?.dataset.category;
    if (activeCategory) updateCategoryPills(activeCategory);
  });

  document.querySelectorAll('#amenities-categories button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category;
      if (!category) return;
      const targetIdx = Array.from(swiper.slides).findIndex(
        (slide) => (slide as HTMLElement).dataset.category === category,
      );
      if (targetIdx >= 0) swiper.slideTo(targetIdx);
    });
  });
</script>

<style is:global>
  .amenities-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }

  .amenities-pagination .swiper-pagination-bullet {
    width: 0.5rem;
    height: 0.5rem;
    background: #E0E0E0;
    border-radius: 9999px;
    opacity: 1;
    transition: width 0.15s, height 0.15s, background 0.15s;
    display: inline-block;
    margin: 0;
  }

  .amenities-pagination .swiper-pagination-bullet-active {
    width: 0.625rem;
    height: 0.625rem;
    background: #6CB4D9;
  }

  #amenities-prev.swiper-button-disabled,
  #amenities-next.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
