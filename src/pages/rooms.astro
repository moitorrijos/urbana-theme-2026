---
import BaseLayout from "../layouts/BaseLayout.astro";
import RoomsHeroCarousel from "../components/RoomsHeroCarousel.astro";
import RoomsByTypeSection from "../components/RoomsByTypeSection.astro";
import { rooms, categories } from "../data/rooms";

const heroImages = rooms.map((r) => r.image);
---

<BaseLayout title="Rooms" currentPage="rooms">
  <RoomsHeroCarousel images={heroImages} />

  <section id="rooms-by-type" class="py-16 bg-light-gray">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1
          class="font-headline text-3xl md:text-4xl font-bold text-text-primary tracking-wide mb-3"
        >
          OUR ROOMS
        </h1>
        <p class="font-body text-base text-medium-gray">
          Find the perfect space for your stay
        </p>
      </div>

      {
        categories.map((category) => (
          <RoomsByTypeSection
            category={category}
            rooms={rooms.filter((r) => r.category === category)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
