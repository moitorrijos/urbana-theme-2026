---
import BaseLayout from "../layouts/BaseLayout.astro";
import RoomsHeroCarousel from "../components/RoomsHeroCarousel.astro";
import { amenities } from "../data/amenities";

const heroImages = amenities.map((a) => a.heroImage);

const socials = [
  {
    label: "Facebook",
    href: "#",
    path: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z",
  },
  {
    label: "Instagram",
    href: "#",
    path: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
  },
  {
    label: "Twitter",
    href: "#",
    path: "M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z",
  },
];

// Flatiron Building, 175 5th Ave, NYC — 40.7411 N, 73.9897 W
const mapSrc =
  "https://www.openstreetmap.org/export/embed.html?bbox=-73.9920%2C40.7395%2C-73.9874%2C40.7427&layer=mapnik&marker=40.7411%2C-73.9897";
const mapLink =
  "https://www.openstreetmap.org/?mlat=40.7411&mlon=-73.9897#map=18/40.7411/-73.9897";
---

<BaseLayout title="Contact" currentPage="contact">
  <RoomsHeroCarousel images={heroImages} />

  <section class="py-16 bg-light-gray">
    <div class="container mx-auto px-4">
      <div class="flex flex-col items-center gap-4 text-center mb-12">
        <span
          class="font-body text-sm font-medium text-gold-warm tracking-[3px]"
        >
          GET IN TOUCH
        </span>
        <h1
          class="font-headline text-3xl md:text-4xl font-bold text-text-primary tracking-wide"
        >
          CONTACT US
        </h1>
        <div class="w-15 h-0.75 bg-sky-blue"></div>
        <p class="font-body text-base text-medium-gray max-w-lg">
          We'd love to hear from you. Reach us by phone, email, or send a
          message using the form below.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-16"
      >
        <div
          class="bg-white p-6 shadow-[0_4px_16px_rgba(0,0,0,0.06)] flex flex-col items-center text-center gap-3"
        >
          <div
            class="w-11 h-11 rounded-full bg-sky-blue/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-sky-blue"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h2
            class="font-headline text-sm font-semibold text-text-primary tracking-wider uppercase"
          >
            Address
          </h2>
          <p class="font-body text-sm text-medium-gray leading-relaxed">
            SOHO 555, Broadway<br />New York, NY
          </p>
        </div>

        <div
          class="bg-white p-6 shadow-[0_4px_16px_rgba(0,0,0,0.06)] flex flex-col items-center text-center gap-3"
        >
          <div
            class="w-11 h-11 rounded-full bg-sky-blue/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-sky-blue"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <h2
            class="font-headline text-sm font-semibold text-text-primary tracking-wider uppercase"
          >
            Phone
          </h2>
          <a
            href="tel:+12122204519"
            class="font-body text-sm text-medium-gray hover:text-sky-blue transition-colors"
          >
            +212-220-4519
          </a>
        </div>

        <div
          class="bg-white p-6 shadow-[0_4px_16px_rgba(0,0,0,0.06)] flex flex-col items-center text-center gap-3"
        >
          <div
            class="w-11 h-11 rounded-full bg-sky-blue/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-sky-blue"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h2
            class="font-headline text-sm font-semibold text-text-primary tracking-wider uppercase"
          >
            Email
          </h2>
          <a
            href="mailto:info@urbana.com"
            class="font-body text-sm text-medium-gray hover:text-sky-blue transition-colors"
          >
            info@urbana.com
          </a>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4 mb-12">
        <h2
          class="font-headline text-sm font-semibold text-text-primary tracking-wider uppercase"
        >
          Follow Us
        </h2>
        <div class="flex gap-4">
          {
            socials.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="w-11 h-11 rounded-full bg-white shadow-[0_2px_8px_rgba(0,0,0,0.06)] flex items-center justify-center text-text-primary hover:bg-sky-blue hover:text-white transition-colors"
              >
                <svg
                  class="w-5 h-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  set:html={`<path d="${s.path}"/>`}
                />
              </a>
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
          <h2
            class="font-headline text-2xl text-text-primary uppercase tracking-wide mb-6"
          >
            Send Us a Message
          </h2>
          <form class="flex flex-col gap-4" action="/contact" method="post">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="flex flex-col">
                <label
                  for="name"
                  class="font-body text-xs font-semibold text-medium-gray uppercase mb-2"
                >
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="border border-border-gray bg-white px-3 py-2.5 font-body text-sm text-text-primary focus:outline-none focus:border-sky-blue"
                />
              </div>
              <div class="flex flex-col">
                <label
                  for="email"
                  class="font-body text-xs font-semibold text-medium-gray uppercase mb-2"
                >
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="border border-border-gray bg-white px-3 py-2.5 font-body text-sm text-text-primary focus:outline-none focus:border-sky-blue"
                />
              </div>
            </div>

            <div class="flex flex-col">
              <label
                for="subject"
                class="font-body text-xs font-semibold text-medium-gray uppercase mb-2"
              >
                Subject
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="border border-border-gray bg-white px-3 py-2.5 font-body text-sm text-text-primary focus:outline-none focus:border-sky-blue"
              />
            </div>

            <div class="flex flex-col">
              <label
                for="message"
                class="font-body text-xs font-semibold text-medium-gray uppercase mb-2"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="border border-border-gray bg-white px-3 py-2.5 font-body text-sm text-text-primary focus:outline-none focus:border-sky-blue resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-gold-warm hover:bg-amber-600 text-white font-body font-semibold text-sm py-3 rounded-sm transition-colors uppercase mt-2"
            >
              Send Message
            </button>
          </form>
        </div>

        <div
          class="bg-white shadow-[0_4px_16px_rgba(0,0,0,0.06)] overflow-hidden flex flex-col"
        >
          <iframe
            src={mapSrc}
            title="Map showing the Flatiron Building, New York"
            loading="lazy"
            class="w-full flex-1 min-h-80 border-0"></iframe>
          <div class="p-4 border-t border-border-gray">
            <p
              class="font-body text-xs font-semibold text-medium-gray uppercase tracking-wider mb-1"
            >
              Nearby Landmark
            </p>
            <p class="font-body text-sm text-text-primary">
              Flatiron Building · 175 5th Ave, New York
            </p>
            <a
              href={mapLink}
              target="_blank"
              rel="noopener"
              class="font-body text-xs text-sky-blue hover:text-sky-blue-light transition-colors font-semibold"
            >
              View larger map →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
